    {
      "cell_type": "markdown",
      "source": [
        "# Próximo token de uma frase"
      ],
      "metadata": {
        "id": "BKCqbGlfUx20"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "text = \"The king lives in the\"\n",
        "inputs = tokenizer(text, return_tensors=\"pt\")\n",
        "\n",
        "with torch.no_grad():\n",
        "    outputs = model(**inputs)\n",
        "    logits = outputs.logits\n",
        "\n",
        "next_token_logits = logits[0, -1, :]\n",
        "\n",
        "probs = torch.softmax(next_token_logits, dim=-1)\n",
        "\n",
        "next_token_id = torch.argmax(probs).item()\n",
        "next_token = tokenizer.decode([next_token_id])\n",
        "\n",
        "print(\"Frase:\", text)\n",
        "print(\"Próximo token mais provável:\", repr(next_token))\n",
        "print(\"Probabilidade:\", probs[next_token_id].item())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "fAMyP5eJU1px",
        "outputId": "d6b57acb-0716-44e6-c725-d8181516644d"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Frase: The king lives in the\n",
            "Próximo token mais provável: ' heart'\n",
            "Probabilidade: 0.03182327002286911\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "top_k = 10\n",
        "top_probs, top_ids = torch.topk(probs, k=top_k)\n",
        "\n",
        "print(f\"Top {top_k} próximos tokens:\")\n",
        "for rank, (token_id, prob) in enumerate(zip(top_ids.tolist(), top_probs.tolist()), start=1):\n",
        "    token_str = tokenizer.decode([token_id])\n",
        "    print(f\"{rank:2d}. {repr(token_str):15s}  prob={prob:.6f}\")"
      ],
