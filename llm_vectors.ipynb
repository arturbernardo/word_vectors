      "source": [
        "import torch\n",
        "from transformers import AutoTokenizer, AutoModelForCausalLM"
      ],
      "metadata": {
        "id": "58HV-z7Q_yLm"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "MODEL_NAME = \"distilgpt2\"\n",
        "\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
        "model = AutoModelForCausalLM.from_pretrained(MODEL_NAME)\n",
        "\n",
        "embedding_matrix = model.get_input_embeddings().weight.detach()\n",
        "\n",
        "print(\"Shape da matriz de embeddings:\", tuple(embedding_matrix.shape))\n",
        "print(\"Tamanho do vocabulário:\", embedding_matrix.shape[0])\n",
        "print(\"Dimensão dos embeddings:\", embedding_matrix.shape[1])"
      ],
